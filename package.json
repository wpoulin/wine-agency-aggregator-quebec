{
  "name": "wine-agency-aggregator-quebec",
  "version": "0.1.0",
  "private": true,
  "description": "Aggregate and normalize wine inventory from Quebec-licensed agencies (SAQ + private).",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @wine/api db:generate",
    "db:migrate": "pnpm --filter @wine/api db:migrate",
    "db:studio": "pnpm --filter @wine/api db:studio"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.3.0",
    "typescript": "^5.6.3"
  }
}
